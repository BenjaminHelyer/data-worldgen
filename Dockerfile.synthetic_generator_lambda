# Worker Lambda container: SQS-triggered synthetic generator (seed chunks).
# Build: docker build -f Dockerfile.synthetic_generator_lambda -t <ecr-repo>:tag .
# Terraform variable lambda_image_uri must point at this image; handler is lambda_handler below.

FROM public.ecr.aws/lambda/python:3.12

COPY pyproject.toml README.md ./
COPY src ./src

RUN pip install --no-cache-dir pip setuptools wheel \
    && pip install --no-cache-dir .

CMD ["world_builder.lambda_synthetic_worker.lambda_handler"]
